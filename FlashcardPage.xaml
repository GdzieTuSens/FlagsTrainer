<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FlagsTrainer.ViewModels"
             x:Class="FlagsTrainer.FlashcardPage"
             x:DataType="viewmodels:FlashcardViewModel"
             Title="Nauka">

    <Grid Padding="32" RowSpacing="24" RowDefinitions="Auto,*,Auto">

        <!-- Loading spinner -->
        <ActivityIndicator Grid.RowSpan="3"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           WidthRequest="64" HeightRequest="64"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- ── Row 0: progress ─────────────────────────────────────────────── -->
        <Label Grid.Row="0"
               IsVisible="{Binding IsNotLoading}"
               Text="{Binding ProgressText}"
               HorizontalOptions="Center"
               FontSize="18"
               TextColor="Gray" />

        <!-- ── Row 1: card ────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsNotLoading}"
                Stroke="LightGray" StrokeThickness="1"
                StrokeShape="RoundRectangle 20"
                Padding="40"
                VerticalOptions="Fill">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FlipCommand}" />
            </Border.GestureRecognizers>

            <Grid>

                <!-- ══ FRONT ══ -->
                <VerticalStackLayout IsVisible="{Binding IsNotFlipped}"
                                     Spacing="24"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">

                    <!-- Flag (FlagToCountry mode) -->
                    <Border IsVisible="{Binding ShowFlagOnFront}"
                            Stroke="#D0D0D0" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 8"
                            WidthRequest="360" HeightRequest="240">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Image Source="{Binding CurrentCountry.FlagImage}"
                               Aspect="AspectFit" />
                    </Border>

                    <!-- Text question (CountryToFlag or CapitalToCountry mode) -->
                    <Label Text="{Binding FrontText}"
                           IsVisible="{Binding ShowTextOnFront}"
                           FontSize="52"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{Binding FrontHint}"
                           FontSize="18" TextColor="Gray"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- ══ BACK ══ -->
                <VerticalStackLayout IsVisible="{Binding IsFlipped}"
                                     Spacing="16"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">

                    <!-- Flag on back (CountryToFlag or CapitalToCountry mode) -->
                    <Border IsVisible="{Binding ShowFlagOnBack}"
                            Stroke="#D0D0D0" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 8"
                            WidthRequest="300" HeightRequest="200">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Image Source="{Binding CurrentCountry.FlagImage}"
                               Aspect="AspectFit" />
                    </Border>

                    <!-- Country name (hidden in CountryToFlag — user already knew it) -->
                    <Label Text="{Binding BackNameText}"
                           IsVisible="{Binding ShowNameOnBack}"
                           FontSize="44" FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <!-- Capital always shown on back -->
                    <Label Text="{Binding BackCapitalText}"
                           FontSize="30" TextColor="Gray"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding BackHint}"
                           FontSize="18" TextColor="Gray"
                           HorizontalOptions="Center"
                           Margin="0,12,0,0" />
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- ── Row 2: buttons ────────────────────────────────────────────── -->
        <Grid Grid.Row="2"
              IsVisible="{Binding IsNotLoading}"
              ColumnDefinitions="*,20,*"
              HeightRequest="72">

            <Button Grid.Column="0"
                    Text="✗  Nie umiem"
                    Command="{Binding DontKnowCommand}"
                    IsVisible="{Binding AnswerButtonsVisible}"
                    FontSize="20"
                    BackgroundColor="#E53935" TextColor="White" />

            <Button Grid.Column="2"
                    Text="✓  Umiem"
                    Command="{Binding KnowCommand}"
                    IsVisible="{Binding AnswerButtonsVisible}"
                    FontSize="20"
                    BackgroundColor="#43A047" TextColor="White" />

            <Label Grid.Column="0" Grid.ColumnSpan="3"
                   Text="Dotknij kartę, żeby ją odwrócić"
                   IsVisible="{Binding IsNotFlipped}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="18" TextColor="Gray" />
        </Grid>

    </Grid>

</ContentPage>
